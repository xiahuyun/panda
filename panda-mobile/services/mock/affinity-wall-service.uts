]

const randomIndex = (max: number): number => {
  return Math.floor(Math.random() * max)
}

export const fetchRandomAffinityProfile = (): Promise<any> => {
  return new Promise((resolve) => {
    setTimeout(() => {
      const index = randomIndex(profilePool.length)
      resolve(profilePool[index])
    }, AFFINITY_LOADING_DELAY_MS)
  })
}

