const AFFINITY_LOADING_DELAY_MS = 600
import { AFFINITY_PROFILES_MOCK } from "../../mock/affinity-profiles.mock.uts"

const randomIndex = (max: number): number => {
  return Math.floor(Math.random() * max)
}

export const fetchRandomAffinityProfile = (): Promise<any> => {
  return new Promise((resolve) => {
    setTimeout(() => {
      const index = randomIndex(AFFINITY_PROFILES_MOCK.length)
      resolve(AFFINITY_PROFILES_MOCK[index])
    }, AFFINITY_LOADING_DELAY_MS)
  })
}
